<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{% if title and title != "Home" %}{{ title }} | {% endif %}woodson42</title>
    <style>
      * {
        box-sizing: border-box;
      }

      html {
        background: oklch(0.975 0.012 92);
      }

      body {
        max-width: 48rem;
        margin: 2rem auto;
        padding: 0 1rem 3rem;
        color: #222;
        font-family: Georgia, "Times New Roman", serif;
        line-height: 1.6;
      }

      a {
        color: #0645ad;
      }

      a:hover {
        text-decoration: underline;
      }

      img {
        max-width: 100%;
        height: auto;
      }

      .site-title {
        margin: 0;
      }

      .site-title a {
        color: inherit;
      }

      .essay-header {
        margin-bottom: 1.5rem;
      }

      .eyebrow {
        margin: 0 0 0.5rem;
        color: #666;
        font-size: 0.95rem;
      }

      h1 {
        margin: 0 0 1rem;
        line-height: 1.2;
      }

      h2,
      h3 {
        line-height: 1.3;
      }

      p,
      ul,
      ol {
        margin: 0 0 1rem;
      }

      blockquote {
        margin: 1rem 0;
        padding-left: 1rem;
        border-left: 3px solid #ccc;
        font-style: italic;
      }

      .home-lead,
      .archive-head,
      .site-footer,
      .masthead {
        margin-bottom: 1rem;
      }

      .essay-list {
        padding-left: 1.25rem;
      }

      .essay-list li {
        margin-bottom: 0.5rem;
      }

      .essay-list time {
        color: #666;
        display: block;
        font-size: 0.95rem;
      }

      .site-footer {
        margin-top: 2rem;
        padding-top: 1rem;
        border-top: 1px solid #ddd;
        color: #666;
      }
    </style>
  </head>
  <body>
    <div class="page">
      <header class="masthead">
        <p class="site-title"><a href="/">woodson42</a></p>
        <p class="eyebrow">Essays, notes, and worthwhile fragments</p>
      </header>

      <main class="content">
        {% if showTitle != false %}
          <header class="essay-header">
            {% if date %}
              <p class="eyebrow">
                <time datetime="{{ date | htmlDateString }}">{{ date | readableDate }}</time>
              </p>
            {% endif %}
            <h1>{{ title }}</h1>
          </header>
        {% endif %}

        <div class="prose">
          {{ content | safe }}
        </div>
      </main>

      <footer class="site-footer">
        Written with care. Published with Eleventy.
      </footer>
    </div>
  </body>
</html>
